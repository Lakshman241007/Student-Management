{
  "version": 2,
  "builds": [
    {
      "src": "**/*.{html,css,js}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/student", "dest": "/student.html" },
    { "src": "/teacher", "dest": "/teacher.html" },
    { "src": "/management", "dest": "/management.html" },
    { "src": "/management-login", "dest": "/management_login.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}